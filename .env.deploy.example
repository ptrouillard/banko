# Configuration de déploiement o2switch
# Copier ce fichier en .env.deploy et remplir les valeurs
# NE PAS commiter .env.deploy (déjà dans .gitignore)

# Hôte SSH o2switch (visible dans cPanel > SSH Access)
DEPLOY_HOST=mondomaine.o2switch.net

# Utilisateur cPanel
DEPLOY_USER=monuser

# Chemin absolu du dossier de l'application sur le serveur
# (visible dans cPanel > Node.js Selector > chemin de l'app)
DEPLOY_PATH=/home/monuser/banko

# Chemin local vers la clé SSH (laisser vide pour utiliser ~/.ssh/id_rsa)
DEPLOY_SSH_KEY=~/.ssh/id_rsa
